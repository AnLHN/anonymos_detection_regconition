CAMERA_DOOR_67B_PASSWORD=change-me
CAMERA_DOOR_67B_RTSP=rtsp://admin:password@192.168.2.223:554/Streaming/Channels/101

CAMERA_AI_PM_1_ID=ai_pm_1
