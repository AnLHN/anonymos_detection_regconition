# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=7001
POSTGRES_DATABASE=face_db
POSTGRES_USER=face_user
POSTGRES_PASSWORD=change-me
POSTGRES_DSN=host=localhost port=7001 dbname=face_db user=face_user password=change-me

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=7002
QDRANT_URL=http://localhost:7002
QDRANT_COLLECTION=employee_faces
QDRANT_VECTOR_SIZE=512
QDRANT_DISTANCE=Cosine

# InsightFace
INSIGHTFACE_DEVICE=cpu
INSIGHTFACE_MODEL_PACK=buffalo_l
INSIGHTFACE_DETECTION_MODEL=buffalo_l
INSIGHTFACE_RECOGNITION_MODEL=buffalo_l
FACE_THRESHOLD=0.60
MIN_DETECTION_SCORE=0.75
MIN_FACE_WIDTH=60
MIN_FACE_HEIGHT=60
TOP_K=5

# Runtime
UNKNOWN_STABLE_FRAMES=5
UNKNOWN_ALERT_COOLDOWN_SECONDS=30
WORKING_HOUR_START=08:00
WORKING_HOUR_END=17:30
RESTRICTED_ZONES=restricted_area,server_room,warehouse
GATE_ZONES=gate
UNKNOWN_GATE_WARNING_FRAMES=8

# Backend
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_API_BASE=http://localhost:8000

# Default camera
DEFAULT_CAMERA_ID=door_67b
DEFAULT_CAMERA_SOURCE=rtsp://user:password@camera-ip:554/Streaming/Channels/101
DEFAULT_DISPLAY_WIDTH=1280
DEFAULT_DISPLAY_HEIGHT=720
DEFAULT_AI_INTERVAL=0.7
DEFAULT_RECONNECT_DELAY=5

# Camera registry examples
CAMERA_DOOR_67B_ID=door_67b
CAMERA_DOOR_67B_NAME=Cửa ra vào 67B
CAMERA_DOOR_67B_IP=192.168.2.223
